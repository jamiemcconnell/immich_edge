# ================================================
# IMMICH EDGE CACHE - Configuration
# Copy this file to .env and fill in your values.
# ================================================

# ------------------------------------------------
# REQUIRED
# ------------------------------------------------

# Internal URL of your Immich instance (reachable from this VPS)
# Use your Tailscale/WireGuard IP, or a local IP if on the same network.
IMMICH_INTERNAL_URL=http://192.168.1.x:2283

# Public domain for this edge cache (must have DNS A record pointing here)
EDGE_DOMAIN=immich.yourdomain.com

# Email for Let's Encrypt certificate notifications
SSL_EMAIL=you@example.com

# ------------------------------------------------
# CACHE
# ------------------------------------------------

# Cache mode: proxy (recommended) or static
# proxy  — nginx caches assets as users browse; no rclone needed
# static — rclone syncs thumbs/videos from home server continuously
CACHE_MODE=proxy

# Maximum total cache size on disk
CACHE_MAX_SIZE=50g

# Cache TTL for thumbnails and videos
CACHE_TTL=365d

# Rate limit per IP (requests per second)
RATE_LIMIT=20

# ------------------------------------------------
# RCLONE (static mode only — requires COMPOSE_PROFILES=static)
# ------------------------------------------------

# Directory containing rclone.conf, SSH key, and known_hosts
# key_file and known_hosts_file in rclone.conf must reference /etc/immich-edge/<filename>
RCLONE_DIR=/etc/immich-edge

# Remote name as defined in rclone.conf
RCLONE_REMOTE=homeserver

# Base path to Immich data directory on remote
RCLONE_IMMICH_PATH=/mnt/data/immich

# Sync interval in seconds (0 = one-time seed only, then exit)
RCLONE_SYNC_INTERVAL=60

# ------------------------------------------------
# ADVANCED (safe to leave as defaults)
# ------------------------------------------------

# Nginx worker processes (auto = one per CPU core)
NGINX_WORKERS=auto

# URL patterns matched for caching (override if Immich API paths ever change)
CACHE_PATTERN_THUMBS=^/api/assets/([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})/thumbnail
CACHE_PATTERN_VIDEOS=^/api/assets/([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})/video/playback
