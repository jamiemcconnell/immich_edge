# ================================================
# IMMICH EDGE CACHE - Configuration
# Copy this file to .env and fill in your values.
# ================================================

# ------------------------------------------------
# REQUIRED
# ------------------------------------------------

# Internal URL of your Immich instance (reachable from this VPS)
# Use your Tailscale/WireGuard IP, or a local IP if on the same network.
IMMICH_INTERNAL_URL=http://192.168.1.x:2283

# Pangolin -> nginx trusted proxy CIDR(s) or IP(s), comma-separated.
# Examples:
# - Single host IP: 172.20.0.10
# - CIDR: 172.20.0.0/16
# - Multiple: 172.20.0.0/16,100.64.0.0/10
TRUSTED_PROXIES=172.20.0.0/16

# ------------------------------------------------
# CACHE
# ------------------------------------------------

# Cache mode: proxy (recommended) or static
# proxy  — nginx caches assets as users browse; no sync daemon needed
# static — sync service pulls thumbs/videos from home server continuously
CACHE_MODE=proxy

# Maximum total cache size on disk
CACHE_MAX_SIZE=50g

# Cache TTL for thumbnails and videos
CACHE_TTL=365d

# Rate limit per IP (requests per second)
RATE_LIMIT=20

# Bind nginx only where Pangolin can reach it (safer default is localhost)
NGINX_BIND_ADDRESS=127.0.0.1
NGINX_PORT=2284

# Optional benchmark helper target (public Pangolin URL)
# EDGE_URL=https://photos.example.com

# ------------------------------------------------
# RSYNC (static mode only — requires COMPOSE_PROFILES=static)
# ------------------------------------------------

# Source path containing Immich media directories (thumbs, encoded-video, profile)
# Examples:
# - rsync daemon over Tailscale: rsync://100.64.1.10/immich
# - SSH transport: user@100.64.1.10:/mnt/data/immich
RSYNC_SOURCE=rsync://100.64.1.10/immich

# Sync interval in seconds (0 = one-time seed only, then exit)
RSYNC_SYNC_INTERVAL=60

# Optional extra rsync flags
# Default if empty: -a --delete --stats --human-readable --timeout=30 --contimeout=10
RSYNC_FLAGS=

# ------------------------------------------------
# ADVANCED (safe to leave as defaults)
# ------------------------------------------------

# Published image settings (used by compose.yaml)
IMAGE_PREFIX=ghcr.io/jamiemcconnell/immich-edge
IMAGE_TAG=latest

# Nginx worker processes (auto = one per CPU core)
NGINX_WORKERS=auto

# URL patterns matched for caching (override if Immich API paths ever change)
CACHE_PATTERN_THUMBS=^/api/assets/([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})/thumbnail
CACHE_PATTERN_VIDEOS=^/api/assets/([a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12})/video/playback

# Proxy cache tuning
CACHE_MIN_USES=1
CACHE_BACKGROUND_UPDATE=on
